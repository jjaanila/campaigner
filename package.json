{
  "name": "campaigner",
  "description": "Dungeons and Dragons campaign framework",
  "version": "2.0.0",
  "author": "Janne Jaanila (https://github.com/jjaanila)",
  "contributors": [
    "Taneli Hukkinen (https://github.com/hukkin)"
  ],
  "license": "MIT",
  "private": false,
  "main": "./src/index.js",
  "homepage": "https://github.com/jjaanila/campaigner",
  "repository": {
    "type": "git",
    "url": "https://github.com/jjaanila/campaigner.git"
  },
  "files": [
    "src/**/*",
    "!src/**/*.test.js",
    "babel.config.js",
    "webpack.config.js",
    "templates",
    "scripts"
  ],
  "bin": {
    "campaigner": "./src/campaigner.js"
  },
  "scripts": {
    "deploy-example": "npm run build && gh-pages -d dist",
    "prepare": "husky",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:watch": "jest --watch",
    "start": "cross-env webpack serve --mode=development --open --hot",
    "build": "rm -rf ./dist/* && cross-env webpack --mode=production --progress",
    "validate": "node ./scripts/validate.js",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "eslint": "eslint src e2e scripts *.js --ext .vue,.js --max-warnings=0",
    "eslint:fix": "npm run eslint -- --fix"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ],
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@popperjs/core": "^2.11.8",
    "@webdiscus/pug-loader": "^2.11.1",
    "babel-loader": "^10.1.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "fuse.js": "^7.1.0",
    "gh-pages": "^3.2.3",
    "html-webpack-plugin": "^5.6.6",
    "image-webpack-loader": "^8.1.0",
    "jsonschema": "^1.4.0",
    "lodash": "^4.17.21",
    "mini-css-extract-plugin": "^2.10.1",
    "normalize.css": "^8.0.1",
    "pug": "^3.0.4",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "vue": "^3.5.30",
    "vue-inline-svg": "^4.0.1",
    "vue-loader": "^17.4.2",
    "vue3-click-away": "^1.2.4",
    "vuex": "^4.1.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "axe-core": "^4.4.1",
    "eslint": "^8.11.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^2.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.33.0",
    "http-server": "^14.1.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "semantic-release": "^19.0.5"
  },
  "engine": {
    "node": ">=18.0.0"
  }
}
